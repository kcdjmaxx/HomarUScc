{
  "name": "homaruscc",
  "version": "0.5.0",
  "description": "MCP server that gives Claude Code a body — messaging, memory, identity, timers, browser automation, and dreams",
  "type": "module",
  "main": "dist/mcp-proxy.js",
  "bin": {
    "homaruscc": "dist/cli.js"
  },
  "files": [
    "dist/",
    "dashboard/dist/",
    "bin/",
    "skills/",
    "identity.example/",
    "config.example.json",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && tsc -p src/vault-indexer/tsconfig.json",
    "dev": "tsc --watch",
    "start": "node dist/mcp-server.js",
    "start:proxy": "node dist/mcp-proxy.js",
    "start:backend": "node dist/backend.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:dashboard": "cd dashboard && npm run build",
    "dev:dashboard": "cd dashboard && npm run dev",
    "setup": "bash bin/install-skills"
  },
  "author": "Max Ross",
  "license": "MIT",
  "keywords": [
    "mcp",
    "claude-code",
    "ai",
    "event-loop",
    "telegram",
    "dashboard"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.7.0",
    "croner": "^9.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "imapflow": "^1.2.10",
    "mailparser": "^3.9.4",
    "mqtt": "^5.15.0",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.58.2",
    "sqlite-vec": "^0.1.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
